{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compass.ai/schemas/opportunity.schema.json",
  "title": "Opportunity",
  "description": "A single AI opportunity recommendation with full reasoning, evidence, and dependencies.",
  "type": "object",
  "properties": {
    "opportunityId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this opportunity"
    },
    "opportunityMapId": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the parent opportunity map"
    },
    "rank": {
      "type": "integer",
      "minimum": 1,
      "description": "Rank position within the opportunity map"
    },
    "title": {
      "type": "string",
      "description": "Human-readable opportunity title"
    },
    "department": {
      "type": "string",
      "enum": ["Sales", "Marketing", "Customer Success", "Support", "Finance", "Product", "Engineering", "People/HR", "Legal", "Operations"],
      "description": "Primary department this opportunity addresses"
    },
    "workflowRef": {
      "type": "string",
      "description": "Reference to the workflow this opportunity addresses"
    },
    "problem": {
      "type": "string",
      "description": "Clear description of the operational problem this opportunity solves"
    },
    "hypothesis": {
      "type": "string",
      "description": "The pre-assessment hypothesis this opportunity validates or invalidates"
    },
    "businessImpact": {
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "Description of the business impact" },
        "estimatedImpact": { "type": "string", "description": "Estimated quantitative or qualitative impact" },
        "impactType": {
          "type": "string",
          "enum": ["Revenue", "Cost", "Efficiency", "Quality", "Compliance", "Experience"],
          "description": "Category of business impact"
        },
        "confidence": { "$ref": "#/$defs/confidenceLevel", "description": "Confidence in the impact estimate" },
        "evidence": { "type": "array", "items": { "$ref": "https://compass.ai/schemas/evidence.schema.json#/$defs/evidenceItem" }, "description": "Evidence supporting the impact estimate" }
      },
      "required": ["description", "impactType"],
      "additionalProperties": false,
      "description": "Business impact assessment for this opportunity"
    },
    "implementationDifficulty": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Very High"],
      "description": "Estimated implementation difficulty"
    },
    "timeToValue": {
      "type": "string",
      "description": "Estimated time to realize value (e.g., '4-6 weeks', '3 months')"
    },
    "confidence": {
      "$ref": "#/$defs/confidenceLevel",
      "description": "Overall confidence in this opportunity recommendation"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk": { "type": "string", "description": "Description of the risk" },
          "category": {
            "type": "string",
            "enum": ["Technical", "Organizational", "Cultural", "Resource", "Compliance"],
            "description": "Risk category"
          },
          "likelihood": {
            "type": "string",
            "enum": ["Low", "Medium", "High"],
            "description": "Likelihood of the risk materializing"
          },
          "impact": {
            "type": "string",
            "enum": ["Low", "Medium", "High", "Critical"],
            "description": "Impact if the risk materializes"
          },
          "mitigation": { "type": "string", "description": "Mitigation strategy" }
        },
        "required": ["risk", "category", "likelihood", "impact"],
        "additionalProperties": false
      },
      "description": "Risks associated with implementing this opportunity"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dependency": { "type": "string", "description": "Description of the dependency" },
          "type": {
            "type": "string",
            "enum": ["System", "Data", "People", "Process", "Approval"],
            "description": "Type of dependency"
          },
          "required": { "type": "boolean", "description": "Whether this dependency is strictly required" },
          "estimatedEffort": { "type": "string", "description": "Estimated effort to resolve this dependency" },
          "status": {
            "type": "string",
            "enum": ["Available", "Needed", "Planned", "Blocked"],
            "description": "Current status of the dependency"
          }
        },
        "required": ["dependency", "type"],
        "additionalProperties": false
      },
      "description": "Dependencies that must be addressed for this opportunity"
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "https://compass.ai/schemas/evidence.schema.json#/$defs/evidenceItem" },
      "description": "All evidence supporting this opportunity"
    },
    "reasoning": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": { "type": "string", "description": "Reasoning step label" },
          "explanation": { "type": "string", "description": "Detailed explanation" },
          "inputs": { "type": "array", "items": { "type": "string" }, "description": "Input references" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Confidence in this reasoning step" }
        },
        "required": ["step", "explanation"],
        "additionalProperties": false
      },
      "description": "Step-by-step reasoning chain for this opportunity"
    },
    "blueprintRef": {
      "type": "string",
      "description": "Reference to the implementation blueprint, if generated"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Arbitrary tags for filtering and categorization"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When this opportunity was generated"
    }
  },
  "required": ["opportunityId", "rank", "title", "department", "problem", "businessImpact", "implementationDifficulty", "confidence", "risks", "dependencies"],
  "additionalProperties": false,
  "$defs": {
    "confidenceLevel": {
      "type": "string",
      "enum": ["Confirmed", "High", "Medium", "Low", "Unknown"],
      "description": "Confidence in the inference or recommendation"
    },
    "evidenceItem": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["User", "Research", "Inference"], "description": "Evidence class" },
        "source": { "type": "string", "description": "Specific source of evidence" },
        "detail": { "type": "string", "description": "Details of the evidence" },
        "url": { "type": "string", "format": "uri", "description": "Source URL" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the evidence was collected" },
        "confidence": { "$ref": "#/$defs/confidenceLevel", "description": "Confidence in this evidence item" }
      },
      "required": ["type", "source", "detail"],
      "additionalProperties": false,
      "description": "A single evidence item with source and confidence"
    }
  }
}
